# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: only needed for npm run setup:supabase automatic database setup.
# Find it in Supabase Dashboard > Project Settings > Database > Connection string.
SUPABASE_DB_URL=

# OpenAI — optional. Without this, CramDeck uses fallback extraction and quiz/game generation.
OPENAI_API_KEY=

# Google Classroom sync — optional. Required only for live Google Classroom OAuth import.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Canvas / Microsoft sync — optional. Canvas token import works without client credentials,
# but these are reserved for future OAuth deployments.
CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
